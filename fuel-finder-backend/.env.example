# Cache TTLs (seconds)
STATION_CACHE_TTL=3600
PRICE_CACHE_TTL=900

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./fuel_finder.db

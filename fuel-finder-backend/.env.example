# GOV.UK Fuel Finder API credentials
# Register at: https://www.developer.fuel-finder.service.gov.uk/public-api
# You need a GOV.UK One Login, then create an "Information Recipient" application
FUEL_FINDER_CLIENT_ID=your_client_id_here
FUEL_FINDER_CLIENT_SECRET=your_client_secret_here

# Fuel Finder API base URL
FUEL_FINDER_BASE_URL=https://www.fuel-finder.service.gov.uk

# Cache TTLs (seconds)
STATION_CACHE_TTL=3600
PRICE_CACHE_TTL=900

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./fuel_finder.db

# ── UK — GOV.UK Fuel Finder ──────────────────────────────────────────────────
# Register at: https://www.developer.fuel-finder.service.gov.uk/public-api
FUEL_FINDER_CLIENT_ID=your_client_id_here
FUEL_FINDER_CLIENT_SECRET=your_client_secret_here
FUEL_FINDER_BASE_URL=https://www.fuel-finder.service.gov.uk
FUEL_FINDER_USER_AGENT=FuelFinderBackend/0.1
FUEL_FINDER_AUTH_BACKOFF_SECONDS=300
DIAGNOSTICS_TOKEN=
UK_DATA_SOURCE=api
ADMIN_IMPORT_TOKEN=

# ── Germany — Tankerkönig ─────────────────────────────────────────────────────
# Register free at: https://creativecommons.tankerkoenig.de
TANKERKOENIG_API_KEY=

# ── Netherlands — ANWB ────────────────────────────────────────────────────────
# Key obtained by intercepting ANWB iOS app traffic via Proxyman
ANWB_API_KEY=

# Cache TTLs (seconds)
STATION_CACHE_TTL=3600
PRICE_CACHE_TTL=900

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Leave DATABASE_PATH unset on Railway if a volume is attached; the app will use
# $RAILWAY_VOLUME_MOUNT_PATH/fuel_finder.db automatically.
DATABASE_PATH=./fuel_finder.db
DATABASE_URL=sqlite+aiosqlite:///./fuel_finder.db
